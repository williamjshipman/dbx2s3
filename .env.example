# Dropbox Configuration
DROPBOX_TOKEN=your_dropbox_access_token_here

# Storage Configuration
# Options: s3, aws, azure
STORAGE_TYPE=s3

# S3/AWS Configuration (for STORAGE_TYPE=s3 or aws)
S3_BUCKET=your-bucket-name
# Optional for AWS S3: omit these to use IAM/default AWS credentials
S3_ACCESS_KEY=your-access-key-id
S3_SECRET_KEY=your-secret-access-key
S3_REGION=us-east-1
# Optional: For S3-compatible storage (MinIO, DigitalOcean Spaces, etc.)
# S3_ENDPOINT=https://your-custom-endpoint.com

# Azure Configuration (for STORAGE_TYPE=azure)
# AZURE_STORAGE_CONNECTION_STRING=your-connection-string
# AZURE_CONTAINER=your-container-name

# Optional: State file location for incremental backups
STATE_FILE=.dbx2s3_state.json
